{
  "name": "@kud/gtv-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Control your Google TV from the CLI",
  "bin": {
    "gtv": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:pair": "tsx src/index.tsx pair",
    "dev:discover": "tsx src/index.tsx discover --select",
    "dev:tui": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "build:watch": "tsup src/index.tsx --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "androidtv-remote": "^1.0.10",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
