{
  "name": "@kud/gtv-cli",
  "version": "0.3.2",
  "type": "module",
  "description": "Control your Google TV from the CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/gtv-cli.git"
  },
  "bin": {
    "gtv": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:pair": "tsx src/index.tsx pair",
    "dev:discover": "tsx src/index.tsx discover --select",
    "dev:tui": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "build:watch": "tsup src/index.tsx --format esm --dts --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@kud/gtv": "0.1.2",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ink": "7.1.0",
    "ink-spinner": "5.0.0",
    "inquirer": "13.4.3",
    "ora": "9.4.0",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
